<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Automation Suite">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    <test name="User Authentication Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>
    <test name="Product Listing Tests">
        <classes>
            <class name="tests.ProductTest"/>
        </classes>
    </test>
    <test name="Shopping Cart Tests">
        <classes>
            <class name="tests.CartTest"/>
        </classes>
    </test>
    <test name="Order History Tests">
        <classes>
            <class name="tests.OrderTest"/>
        </classes>
    </test>
    <test name="Form Validation Tests">
        <classes>
            <class name="tests.ValidationTest"/>
        </classes>
    </test>
</suite>
